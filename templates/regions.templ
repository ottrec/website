package templates

import (
	"github.com/ottrec/website/pkg/ottrecidx"
	"github.com/ottrec/website/static"
)

// regionsMapBody is the "regions-map" about block: the interactive Leaflet map
// container (filled in by static/regions.ts) and its legend. The data island
// and script that drive it are emitted by regionsMapFoot.
templ regionsMapBody(data ottrecidx.DataRef) {
	<div class="region-map" id="region-map">
		<noscript>
			<div class="region-noscript">
				<p>The map needs JavaScript. The regions and sectors are described below.</p>
			</div>
		</noscript>
	</div>
	<p class="region-legend">
		<span class="region-key region-key-shade">Region</span>
		<span class="region-key region-key-line">Sector boundary</span>
		<span class="region-key region-key-dot">Facility</span>
	</p>
}

// regionsMapFoot emits the regions map's JSON data island and the script that
// reads it, at the end of <body>.
templ regionsMapFoot(data ottrecidx.DataRef) {
	@templ.JSONScript("regions-data", buildRegionsData(data))
	<script src={ static.Path(static.RegionsJS) }></script>
}

// regionsTableBody is the "regions-table" about block: the region centrepoints
// table (the OpenStreetMap label points the regions are derived from).
templ regionsTableBody(data ottrecidx.DataRef) {
	<table class="region-table">
		<thead>
			<tr>
				<th>Name</th>
				<th>Entity Type</th>
				<th class="num">Latitude</th>
				<th class="num">Longitude</th>
			</tr>
		</thead>
		<tbody>
			for _, row := range regionRows() {
				<tr>
					<td>{ row.Name }</td>
					<td>{ row.Class }</td>
					<td class="num">{ row.Lat }</td>
					<td class="num">{ row.Lng }</td>
				</tr>
			}
		</tbody>
	</table>
}
